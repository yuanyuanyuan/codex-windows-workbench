# yaml-language-server: $schema=https://raw.githubusercontent.com/PowerShell/DSC/main/schemas/2023/08/config/document.json
# Native Windows PowerShell 7 core for AI-assisted development.

$schema: https://raw.githubusercontent.com/PowerShell/DSC/main/schemas/2023/08/config/document.json

metadata:
  winget:
    processor: dscv3

resources:
  - type: Microsoft.WinGet/Package
    name: PowerShell
    properties:
      id: Microsoft.PowerShell
      source: winget
      acceptAgreements: true
    metadata:
      description: Install PowerShell 7.
      winget:
        securityContext: elevated

  - type: Microsoft.WinGet/Package
    name: Git
    properties:
      id: Git.Git
      source: winget
      acceptAgreements: true
    metadata:
      description: Install Git for Windows.
      winget:
        securityContext: elevated

  - type: Microsoft.WinGet/Package
    name: GitHubCLI
    properties:
      id: GitHub.cli
      source: winget
      acceptAgreements: true
    metadata:
      description: Install GitHub CLI.
      winget:
        securityContext: elevated

  - type: Microsoft.WinGet/Package
    name: WindowsTerminal
    properties:
      id: Microsoft.WindowsTerminal
      source: winget
      acceptAgreements: true
    metadata:
      description: Install Windows Terminal.
      winget:
        securityContext: elevated

  - type: Microsoft.WinGet/Package
    name: VisualStudioCode
    properties:
      id: Microsoft.VisualStudioCode
      source: winget
      acceptAgreements: true
    metadata:
      description: Install Visual Studio Code.
      winget:
        securityContext: elevated

  - type: Microsoft.WinGet/Package
    name: VCRedistX64
    properties:
      id: Microsoft.VCRedist.2015+.x64
      source: winget
      acceptAgreements: true
    metadata:
      description: Install VC++ runtime used by native tools and winget configure.
      winget:
        securityContext: elevated

  - type: Microsoft.WinGet/Package
    name: NodeLts
    properties:
      id: OpenJS.NodeJS.LTS
      source: winget
      acceptAgreements: true
    metadata:
      description: Install Node.js LTS for agent CLIs and JavaScript projects.
      winget:
        securityContext: elevated

  - type: Microsoft.WinGet/Package
    name: Python313
    properties:
      id: Python.Python.3.13
      source: winget
      acceptAgreements: true
    metadata:
      description: Install Python 3.13.
      winget:
        securityContext: elevated

  - type: Microsoft.WinGet/Package
    name: Uv
    properties:
      id: astral-sh.uv
      source: winget
      acceptAgreements: true
    metadata:
      description: Install uv Python package and environment manager.
      winget:
        securityContext: elevated

  - type: Microsoft.WinGet/Package
    name: DockerCLI
    properties:
      id: Docker.DockerCLI
      source: winget
      acceptAgreements: true
    metadata:
      description: Install Docker CLI without installing or configuring a backend.
      winget:
        securityContext: elevated

  - type: Microsoft.WinGet/Package
    name: Kubectl
    properties:
      id: Kubernetes.kubectl
      source: winget
      acceptAgreements: true
    metadata:
      description: Install kubectl.
      winget:
        securityContext: elevated
